<launch>
    <let name="urdf_path" 
         value="$(find-pkg-share robo_1_description)/urdf/mobile.urdf.xacro" />
    <let name="gazebo_config_path"
         value="$(find-pkg-share robo_1_master)/config/gazebo_bridge.yaml" />
    <let name="rviz_config_path"
         value="$(find-pkg-share my_robot_arm)/rviz/urdf_config.rviz" />


    <!-- publishing the robot urdf -->
    <node pkg="robot_state_publisher" exec="robot_state_publisher">
        <param name="robot_description"
               value="$(command 'xacro $(var urdf_path)')" />
    </node>
    

    <!-- <node pkg="arm_controller_node" exec="arm_controller"/> -->

    <!-- <node pkg="joint_state_publisher_gui" exec="joint_state_publisher_gui" /> -->

    <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
        <arg name="gz_args" value="$(find-pkg-share my_robot_bringup)/worlds/test_world.sdf -r" />
    </include>


    <!-- spawn the robot -->
    <node pkg="ros_gz_sim" exec="create" args="-topic robot_description" />

    <node pkg="ros_gz_bridge" exec="parameter_bridge">  
        <param name="config_file" value="$(var gazebo_config_path)" />
    </node>

    <node pkg="rviz2" exec="rviz2" output="screen" 
          args="-d $(var rviz_config_path)" />
</launch>